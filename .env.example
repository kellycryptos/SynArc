# SynArc DAO Frontend Configuration
# This is a template for environment variables. Copy to .env.local and fill in values.
# IMPORTANT: .env.local is git-ignored and should never be committed.

# === Authentication ===
# Privy App ID for wallet authentication
NEXT_PUBLIC_PRIVY_APP_ID=clt57262n00ldmp0fhz113qep

# === RPC Configuration ===
# Arc Testnet RPC endpoint (optional - falls back to public RPC if not set)
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network

# === Governance Contracts (Arc Testnet - Chain ID: 5042002) ===
# These are the deployed contract addresses. Update after deployment.
NEXT_PUBLIC_GOVERNOR_ADDRESS=0x17D9d585CBB1AF6aa4a3C787116f7ba59651B702
NEXT_PUBLIC_TOKEN_ADDRESS=0x637cA7788aBC956832F389A7BB895D5249FE757B
NEXT_PUBLIC_TREASURY_ADDRESS=0x43b776BA2e614a672dBc98d1aDD01A61Ae8F39Fb

# === Environment Mode ===
# Options: development, staging, production
NEXT_PUBLIC_ENVIRONMENT=development

# === Server-side Secrets (never expose to frontend) ===
# These should ONLY be set on the server or in CI/CD, never in NEXT_PUBLIC_* variables
# Privy webhook signing key (for API routes only)
PRIVY_WEBHOOK_SIGNING_KEY=your_privy_webhook_signing_key_here

# Deployment credentials (for scripts/deploy.ts only)
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here
ARC_RPC_URL=https://rpc.testnet.arc.network
